_sum([-4, -5, 6, -3, -4, 3, 7, -5], 8) == 10", "_extractor_claimType": "behavioral", "_extractor_assertedTruthValue": "true", "_extractor_resolved": true}], "task_id": 559, "verification_result": "PASS", "extracted_function_name": "max_sub_array_sum", "agent_output": "def max_sub_array_sum(arr, n):\n    max_so_far = arr[0]\n    max_ending_here = arr[0]\n\n    for i in range(1, n):\n        max_ending_here = max(arr[i], max_ending_here + arr[i])\n        max_so_far = max(max_so_far, max_ending_here)\n\n    return max_so_far\n\n# Verification of the function with the provided assertions\nassert max_sub_array_sum([-2, -3, 4, -1, -2, 1, 5, -3], 8) == 7\nassert max_sub_array_sum([-3, -4, 5, -2, -3, 2, 6, -4], 8) == 8\nassert max_sub_array_sum([-4, -5, 6, -3, -4, 3, 7, -5], 8) == 10"}
